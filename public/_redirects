# Root redirects to Arabic
/ /ar/ 301

# Serve existing locale paths directly
/en/* /en/:splat 200
/ar/* /ar/:splat 200

# Static assets — serve as-is (don't redirect)
/_next/static/* /_next/static/:splat 200
/favicon.ico /favicon.ico 200
/favicon.svg /favicon.svg 200
/robots.txt /robots.txt 200
/sitemap.xml /sitemap.xml 200
/404.html /404.html 200

# Any path without a locale prefix: redirect to Arabic version
/* /ar/:splat 301
